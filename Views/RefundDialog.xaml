<ContentDialog
    x:Class="DChemist.Views.RefundDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DChemist.Models"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d"
    Title="Process Item Returns"
    PrimaryButtonText="Confirm Refund"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonStyle="{StaticResource PremiumButtonStyle}"
    SecondaryButtonStyle="{StaticResource SecondaryButtonStyle}"
    CornerRadius="16">

    <Grid Width="600" Height="400">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select quantity to return for each item:" Margin="0,0,0,12" Foreground="{StaticResource TextSecondaryBrush}"/>

        <controls:DataGrid Grid.Row="1" x:Name="ItemsGrid"
                           AutoGenerateColumns="False"
                           CanUserSortColumns="False"
                           IsReadOnly="False"
                           HeadersVisibility="All"
                           RowHeight="48">
            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="Medicine" Binding="{Binding MedicineName}" Width="*" IsReadOnly="True"/>
                <controls:DataGridTextColumn Header="Sold" Binding="{Binding Quantity}" Width="80" IsReadOnly="True"/>
                <controls:DataGridTextColumn Header="Already Ret." Binding="{Binding ReturnedQuantity}" Width="100" IsReadOnly="True"/>
                <controls:DataGridTemplateColumn Header="Return Qty" Width="120">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:SaleItem">
                            <NumberBox Value="{Binding ReturnInputQty, Mode=TwoWay}" 
                                       Minimum="0" 
                                       Maximum="{Binding MaxReturnable}" 
                                       SmallChange="1" 
                                       LargeChange="5"
                                       SpinButtonPlacementMode="Compact"
                                       HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <TextBlock Grid.Row="2" x:Name="ErrorMessage" Foreground="Red" FontSize="12" Margin="0,12,0,0" Visibility="Collapsed"/>
    </Grid>
</ContentDialog>
