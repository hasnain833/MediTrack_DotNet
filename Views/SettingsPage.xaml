<Page
    x:Class="DChemist.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DChemist.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Banner -->
        <Border Background="{StaticResource PremiumBackgroundBrush}"
                CornerRadius="0,0,24,24" Padding="40,32">
            <StackPanel Spacing="6">
                <TextBlock Text="Settings" FontSize="32" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Configure system preferences and integrations." FontSize="15" Foreground="#A0AEC0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="32,24,32,32">
            <StackPanel Spacing="32" MaxWidth="1000" HorizontalAlignment="Left">

            <!-- Database Management -->
            <Border Style="{StaticResource PremiumCardStyle}" Margin="0">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Database Operations" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Manage your PostgreSQL database backups and restoration." Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{x:Bind ViewModel.BackupCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE896;" FontSize="14"/>
                                <TextBlock Text="Backup Database"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButtonStyle}" Command="{x:Bind ViewModel.RestoreCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE777;" FontSize="14"/>
                                <TextBlock Text="Restore Database"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- FBR / Fiscal Integration -->
            <Border Style="{StaticResource PremiumCardStyle}" Margin="0">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="FBR Fiscal Integration" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Configure real-time reporting to the FBR IMS system." Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                    </StackPanel>
                    
                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{x:Bind ViewModel.ShowFiscalSettingsCommand}" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE713;" FontSize="14"/>
                            <TextBlock Text="Configure Fiscal Settings"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
