<Page
    x:Class="DChemist.Views.AuditLogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DChemist.Models"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource AppBackgroundBrush}" RequestedTheme="Light">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="{StaticResource PremiumBackgroundBrush}"
                CornerRadius="0,0,24,24" Padding="40,32" Margin="0,0,0,24">
            <StackPanel Spacing="6">
                <TextBlock Text="Audit Logs" FontSize="32" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Track user actions, stock adjustments, and system events." FontSize="15" Foreground="#A0AEC0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="40,0,40,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filters -->
            <Border Style="{StaticResource PremiumCardStyle}" Padding="20" Margin="0,0,0,20">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="6">
                        <TextBlock Text="User" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{x:Bind ViewModel.Users}"
                                  SelectedItem="{x:Bind ViewModel.SelectedUser, Mode=TwoWay}"
                                  DisplayMemberPath="Username"
                                  HorizontalAlignment="Stretch" CornerRadius="8"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock Text="Action" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{x:Bind ViewModel.Actions}"
                                  SelectedItem="{x:Bind ViewModel.SelectedAction, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch" CornerRadius="8"
                                  PlaceholderText="All Actions"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="6">
                        <TextBlock Text="Date" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <CalendarDatePicker Date="{x:Bind ViewModel.SelectedDate, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch" CornerRadius="8"/>
                    </StackPanel>

                    <Button Grid.Column="3" Content="Clear Filters" 
                            Command="{x:Bind ViewModel.ClearFiltersCommand}"
                            Style="{StaticResource TextBlockButtonStyle}"
                            VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                </Grid>
            </Border>

            <!-- Logs Table -->
            <Border Grid.Row="1" Style="{StaticResource PremiumCardStyle}" Padding="0">
                <controls:DataGrid ItemsSource="{x:Bind ViewModel.Logs, Mode=OneWay}"
                                   AutoGenerateColumns="False"
                                   SelectionMode="Single"
                                   GridLinesVisibility="Horizontal"
                                   Background="Transparent">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Time" Binding="{Binding CreatedAt, Converter={StaticResource DateFormatConverter}, ConverterParameter='HH:mm:ss'}" Width="100"/>
                        <controls:DataGridTextColumn Header="User" Binding="{Binding Username}" Width="120"/>
                        <controls:DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="150">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*">
                            <controls:DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                </Style>
                            </controls:DataGridTextColumn.ElementStyle>
                        </controls:DataGridTextColumn>
                        <controls:DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, Converter={StaticResource DateFormatConverter}, ConverterParameter='dd MMM yyyy'}" Width="120"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </Border>

            <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                          Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                          Width="50" Height="50" Foreground="{StaticResource AccentAccent}"/>
        </Grid>
    </Grid>
</Page>
