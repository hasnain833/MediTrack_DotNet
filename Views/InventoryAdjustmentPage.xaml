<Page
    x:Class="DChemist.Views.InventoryAdjustmentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:DChemist.ViewModels"
    xmlns:models="using:DChemist.Models"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource AppBackgroundBrush}" RequestedTheme="Light">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="{StaticResource PremiumBackgroundBrush}"
                CornerRadius="0,0,24,24" Padding="40,32" Margin="0,0,0,24">
            <StackPanel Spacing="6">
                <TextBlock Text="Stock Adjustment" FontSize="32" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Correct shelf counts for discrepancies, damage, or theft." FontSize="15" Foreground="#A0AEC0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="40,0,40,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Search Bar -->
            <Border Grid.Row="0" Style="{StaticResource PremiumCardStyle}" Padding="24" Margin="0,0,0,32">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE721;" FontSize="20" Foreground="{StaticResource AccentAccent}" VerticalAlignment="Center"/>
                        <TextBlock Text="Quick Medicine Search" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBox Grid.Column="1" PlaceholderText="Search medicine name to adjust stock..."
                             Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="48" CornerRadius="12" FontSize="16" Padding="16,8"/>

                    <ComboBox Grid.Column="2" ItemsSource="{x:Bind ViewModel.MedicineResults, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedMedicine, Mode=TwoWay}"
                              PlaceholderText="Select medicine result..."
                              HorizontalAlignment="Stretch" Height="48" CornerRadius="12"
                              Visibility="{x:Bind ViewModel.MedicineResults.Count, Mode=OneWay, Converter={StaticResource CountToVisibilityConverter}}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Medicine">
                                <StackPanel>
                                    <TextBlock Text="{x:Bind Name}" FontWeight="Bold"/>
                                    <TextBlock Text="{x:Bind GenericName}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnSpacing="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="450"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Alerts Dashboard -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="32">
                        <!-- Low Stock Table -->
                        <Border Style="{StaticResource PremiumCardStyle}" Padding="24">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE783;" Foreground="#E67E22" FontSize="20"/>
                                    <TextBlock Text="Low Stock Medicine" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <Border Background="#FFF3CD" CornerRadius="12" Padding="12,2" Margin="8,0,0,0">
                                        <TextBlock Text="{x:Bind ViewModel.LowStockItems.Count, Mode=OneWay}" FontWeight="Bold" Foreground="#856404" FontSize="14"/>
                                    </Border>
                                </StackPanel>

                                <controls:DataGrid ItemsSource="{x:Bind ViewModel.LowStockItems, Mode=OneWay}"
                                                 SelectedItem="{x:Bind ViewModel.SelectedAlertItem, Mode=TwoWay}"
                                                 AutoGenerateColumns="False"
                                                 IsReadOnly="True"
                                                 RowHeight="54"
                                                 MaxHeight="400"
                                                 GridLinesVisibility="Horizontal"
                                                 SelectionMode="Single"
                                                 VerticalScrollBarVisibility="Auto">
                                    <controls:DataGrid.Columns>
                                        <controls:DataGridTextColumn Header="Medicine Name" Binding="{Binding MedicineName}" Width="*" />
                                        <controls:DataGridTemplateColumn Header="Total Units" Width="150">
                                            <controls:DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate x:DataType="models:AlertBatchItem">
                                                    <Border Background="#FEECDC" CornerRadius="4" Padding="12,6" HorizontalAlignment="Left" Margin="12,0">
                                                        <TextBlock Text="{x:Bind StockDisplay}" Foreground="#E67E22" FontWeight="Bold" FontSize="13"/>
                                                    </Border>
                                                </DataTemplate>
                                            </controls:DataGridTemplateColumn.CellTemplate>
                                        </controls:DataGridTemplateColumn>
                                    </controls:DataGrid.Columns>
                                </controls:DataGrid>

                                <TextBlock Text="All medicines have sufficient stock ✓"
                                           Visibility="{x:Bind ViewModel.LowStockItems.Count, Mode=OneWay, Converter={StaticResource EmptyToVisibilityConverter}}"
                                           FontSize="14" Foreground="#27AE60" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Near Expiry Table -->
                        <Border Style="{StaticResource PremiumCardStyle}" Padding="24">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE787;" Foreground="#E53E3E" FontSize="20"/>
                                    <TextBlock Text="Near Expiry Batches" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <Border Background="#FED7D7" CornerRadius="12" Padding="12,2" Margin="8,0,0,0">
                                        <TextBlock Text="{x:Bind ViewModel.NearExpiryItems.Count, Mode=OneWay}" FontWeight="Bold" Foreground="#9B2C2C" FontSize="14"/>
                                    </Border>
                                </StackPanel>

                                <controls:DataGrid ItemsSource="{x:Bind ViewModel.NearExpiryItems, Mode=OneWay}"
                                                 SelectedItem="{x:Bind ViewModel.SelectedAlertItem, Mode=TwoWay}"
                                                 AutoGenerateColumns="False"
                                                 IsReadOnly="True"
                                                 RowHeight="54"
                                                 MaxHeight="400"
                                                 GridLinesVisibility="Horizontal"
                                                 SelectionMode="Single"
                                                 VerticalScrollBarVisibility="Auto">
                                    <controls:DataGrid.Columns>
                                        <controls:DataGridTextColumn Header="Medicine Name" Binding="{Binding MedicineName}" Width="*" />
                                        <controls:DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDisplay}" Width="150" />
                                        <controls:DataGridTemplateColumn Header="Remaining" Width="150">
                                            <controls:DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate x:DataType="models:AlertBatchItem">
                                                    <Border Background="#FED7D7" CornerRadius="4" Padding="12,6" HorizontalAlignment="Left" Margin="12,0">
                                                        <TextBlock Text="{x:Bind DaysLeftDisplay}" Foreground="#E53E3E" FontWeight="Bold" FontSize="13"/>
                                                    </Border>
                                                </DataTemplate>
                                            </controls:DataGridTemplateColumn.CellTemplate>
                                        </controls:DataGridTemplateColumn>
                                    </controls:DataGrid.Columns>
                                </controls:DataGrid>

                                <TextBlock Text="No batches expiring within 30 days ✓"
                                           Visibility="{x:Bind ViewModel.NearExpiryItems.Count, Mode=OneWay, Converter={StaticResource EmptyToVisibilityConverter}}"
                                           FontSize="14" Foreground="#27AE60" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Right: Selection & Adjustment Form -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="20" Padding="0,0,12,0">
                        
                        <!-- Batch Selection (visible when medicine selected) -->
                        <Border Style="{StaticResource PremiumCardStyle}" Padding="20"
                                Visibility="{x:Bind ViewModel.SelectedMedicine, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='Inverse'}">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,4">
                                    <FontIcon Glyph="&#xE912;" FontSize="18" Foreground="{StaticResource AccentAccent}"/>
                                    <TextBlock Text="Active Batches" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                                
                                <ListView ItemsSource="{x:Bind ViewModel.Batches, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedBatch, Mode=TwoWay}"
                                          MaxHeight="200" BorderThickness="1" BorderBrush="#E2E8F0" CornerRadius="12">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:InventoryBatch">
                                            <Grid Padding="16,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{x:Bind BatchNo}" FontWeight="Bold" FontSize="14"/>
                                                    <TextBlock Text="{x:Bind ExpiryDate, Converter={StaticResource DateFormatConverter}, ConverterParameter='MMMM yyyy'}" 
                                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="0">
                                                    <TextBlock Text="{x:Bind RemainingUnits}" HorizontalAlignment="Right"
                                                               FontWeight="ExtraBold" Foreground="{StaticResource AccentAccent}" FontSize="16"/>
                                                    <TextBlock Text="units" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>

                        <!-- Adjustment Form (visible when batch selected) -->
                        <Border Style="{StaticResource PremiumCardStyle}" Padding="24"
                                Visibility="{x:Bind ViewModel.SelectedBatch, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='Inverse'}">
                            <StackPanel Spacing="20">
                                <TextBlock Text="Adjustment Details" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>

                                <Grid ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="System Count" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind ViewModel.SelectedBatch.RemainingUnits, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#4A5568"/>
                                    </StackPanel>

                                    <StackPanel Spacing="6" Grid.Column="1">
                                        <TextBlock Text="Shelf Count" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                        <NumberBox Value="{x:Bind ViewModel.NewQuantity, Mode=TwoWay}"
                                                   PlaceholderText="New count"
                                                   SpinButtonPlacementMode="Compact"
                                                   Height="40" FontSize="18" FontWeight="Bold" CornerRadius="8"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="Reason for adjustment" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{x:Bind ViewModel.Reasons}"
                                              SelectedItem="{x:Bind ViewModel.AdjustmentReason, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch" Height="36" CornerRadius="8"/>
                                </StackPanel>

                                <Border Height="1" Background="#E2E8F0" Margin="0,4"/>

                                <StackPanel Spacing="12">
                                    <Button Content="Update Stock Level"
                                            Command="{x:Bind ViewModel.AdjustStockCommand}"
                                            Style="{StaticResource PremiumButtonStyle}"
                                            Height="48" HorizontalAlignment="Stretch" FontSize="15" FontWeight="Bold"/>

                                    <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                                  Foreground="{StaticResource AccentAccent}" HorizontalAlignment="Center"/>

                                    <Border Background="{x:Bind ViewModel.IsStatusSuccess, Mode=OneWay, Converter={StaticResource StatusBgConverter}}"
                                            CornerRadius="8" Padding="12,8"
                                            Visibility="{x:Bind ViewModel.StatusMessage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='Inverse'}">
                                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                                   Foreground="{x:Bind ViewModel.IsStatusSuccess, Mode=OneWay, Converter={StaticResource StatusFgConverter}}"
                                                   FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Placeholder when nothing selected -->
                        <Border Style="{StaticResource PremiumCardStyle}" Padding="40" Background="#F8FAFC"
                                Visibility="{x:Bind ViewModel.SelectedMedicine, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE783;" FontSize="48" Foreground="#CBD5E1"/>
                                <TextBlock Text="Select a medicine to start adjustment" 
                                           FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" 
                                           HorizontalAlignment="Center" TextAlignment="Center" Width="200"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>

