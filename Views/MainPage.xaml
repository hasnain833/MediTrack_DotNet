<Page
    x:Class="MediTrack.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MediTrack.Views"
    xmlns:vm="using:MediTrack.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#F3F3F3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{ThemeResource PremiumBackgroundBrush}" Padding="0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Spacing="8" Margin="24,0,24,40">
                    <TextBlock Text="MediTrack" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Management System" FontSize="12" Foreground="#CCFFFFFF"/>
                </StackPanel>

                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.NavigationItems}"
                          SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                          SelectionMode="Single" Padding="12,0">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:NavigationItem">
                            <Grid Height="48" Margin="0,4">
                                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center" Margin="12,0">
                                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="{x:Bind Icon}" 
                                              Foreground="White" FontSize="18"/>
                                    <TextBlock Text="{x:Bind Title}" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Margin" Value="0,2"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <StackPanel Grid.Row="2" Margin="24,20" Spacing="12">
                    <Border Height="1" Background="#30FFFFFF" HorizontalAlignment="Stretch"/>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.CurrentUser.FullName, Mode=OneWay}" 
                                       Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.CurrentUser.Role, Mode=OneWay}" 
                                       Foreground="#AAFFFFFF" FontSize="11"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Command="{x:Bind ViewModel.LogoutCommand}"
                                Background="Transparent" BorderThickness="0">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE7E8;" Foreground="#AAFFFFFF"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="White" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0" Padding="24,0">
                <Grid VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}" FontSize="20" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="16">
                        <AutoSuggestBox QueryIcon="Find" PlaceholderText="Quick search..." Width="250" VerticalAlignment="Center"/>
                        <Button Background="Transparent" BorderThickness="0">
                            <FontIcon Glyph="&#xE724;" FontSize="18"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Frame x:Name="ContentFrame" Grid.Row="1" Padding="32"/>
        </Grid>
    </Grid>
</Page>
