<Page
    x:Class="DChemist.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DChemist.Views"
    xmlns:vm="using:DChemist.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DChemist.Models"
    xmlns:utils="using:DChemist.Utils"
    x:Name="PageRoot"
    mc:Ignorable="d">

    <Page.Resources>
        <utils:SidebarLogoutColorConverter x:Key="SidebarLogoutColorConverter"/>
    </Page.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{x:Bind ViewModel.SidebarGridWidth, Mode=OneWay}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource PremiumBackgroundBrush}" Padding="0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Spacing="8" Margin="0,20,0,40">
                    <Button Command="{x:Bind ViewModel.ToggleSidebarCommand}"
                            Style="{StaticResource TextBlockButtonStyle}"
                            HorizontalAlignment="Stretch" Padding="0" Height="44">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE700;" Foreground="White" FontSize="20" HorizontalAlignment="Center"/>
                    </Button>
                    
                    <StackPanel Spacing="2" Margin="24,10,24,0"
                                Visibility="{x:Bind ViewModel.IsSidebarExpanded, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="D. Chemist" FontSize="22" FontWeight="Bold" Foreground="White" TextWrapping="NoWrap"/>
                        <TextBlock Text="Management" FontSize="11" Foreground="#88FFFFFF"/>
                    </StackPanel>
                </StackPanel>

                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.NavigationItems}"
                          SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                          SelectionMode="Single" Padding="12,0"
                          ItemContainerStyle="{StaticResource SidebarItemStyle}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:NavigationItem">
                            <Grid Height="44">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="{x:Bind Icon}" 
                                          FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind Title}" FontSize="14" FontWeight="Medium"
                                           VerticalAlignment="Center" Margin="10,0,0,0"
                                           Visibility="{Binding ViewModel.IsSidebarExpanded, ElementName=PageRoot, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{x:Bind Title}" 
                                             Visibility="{Binding ViewModel.IsSidebarCollapsed, ElementName=PageRoot, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </ToolTipService.ToolTip>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="2" Margin="0,20" Spacing="16">
                    <Border Height="1" Background="#15FFFFFF" HorizontalAlignment="Stretch" Margin="12,0"/>
                    <Grid Margin="0,0" Height="48">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Mini Logout icon (Standard White/Light) -->
                        <Button Grid.Column="0" Command="{x:Bind ViewModel.LogoutCommand}"
                                Style="{StaticResource TextBlockButtonStyle}" 
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="0">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8BB;" 
                                      Foreground="{x:Bind ViewModel.IsSidebarCollapsed, Mode=OneWay, Converter={StaticResource SidebarLogoutColorConverter}}" 
                                      FontSize="20"/>
                        </Button>

                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" Margin="10,0,10,0"
                                    Visibility="{x:Bind ViewModel.IsSidebarExpanded, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{x:Bind ViewModel.CurrentUser.FullName, Mode=OneWay}" 
                                       Foreground="White" FontWeight="SemiBold" FontSize="13" TextWrapping="NoWrap"/>
                            <TextBlock Text="Logout" Foreground="#88FFFFFF" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
        <Frame x:Name="ContentFrame" Grid.Column="1" Padding="0"/>
    </Grid>
</Page>
