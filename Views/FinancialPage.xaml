<Page
    x:Class="DChemist.Views.FinancialPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:vm="using:DChemist.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Search -->
            <RowDefinition Height="*"/>    <!-- Invoice List -->
            <RowDefinition Height="Auto"/> <!-- Divider -->
            <RowDefinition Height="350"/>  <!-- Invoice Details -->
        </Grid.RowDefinitions>

        <!-- Page Banner -->
        <Border Background="{StaticResource PremiumBackgroundBrush}"
                Padding="60,32">
            <StackPanel Spacing="4">
                <TextBlock Text="Invoice Management" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Search invoices and process item returns." FontSize="14" Foreground="#A0AEC0"/>
            </StackPanel>
        </Border>

        <!-- TOP SECTION: Search Controls -->
        <Border Grid.Row="1" Margin="60,24,60,0" Style="{StaticResource PremiumCardStyle}" Padding="32,24">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock Text="Invoice Number" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                    <TextBox PlaceholderText="INV-..." Text="{x:Bind ViewModel.SearchInvoiceTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <CalendarDatePicker Grid.Column="1" 
                                    Header="Date"
                                    Date="{x:Bind ViewModel.SearchDate, Mode=TwoWay}" 
                                    PlaceholderText="Pick a date"
                                    HorizontalAlignment="Stretch"
                                    MinWidth="150"
                                    VerticalAlignment="Bottom"/>

                <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Text="Customer Name" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                    <TextBox PlaceholderText="Search customer..." Text="{x:Bind ViewModel.SearchCustomerTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="12" VerticalAlignment="Bottom">
                    <Button Command="{x:Bind ViewModel.ReprintReceiptCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE749;" FontSize="14"/>
                            <TextBlock Text="Print Copy" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.VoidSaleCommand}" Background="#FEE2E2" Foreground="#DC2626" BorderBrush="Transparent" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE107;" FontSize="14"/>
                            <TextBlock Text="Void Entire Sale" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MIDDLE SECTION: Invoice List -->
        <Border Grid.Row="2" Margin="60,24,60,16" Style="{StaticResource PremiumCardStyle}" Padding="0">
            <controls:DataGrid AutoGenerateColumns="False"
                               ItemsSource="{x:Bind ViewModel.SalesHistory}"
                               SelectedItem="{x:Bind ViewModel.SelectedSale, Mode=TwoWay}"
                               GridLinesVisibility="Horizontal" HeadersVisibility="All"
                               RowHeight="48" BorderThickness="0" Background="Transparent">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Invoice" Binding="{Binding BillNo}" Width="150"/>
                    <controls:DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="180"/>
                    <controls:DataGridTextColumn Header="Customer" Binding="{Binding Customer}" Width="*"/>
                    <controls:DataGridTextColumn Header="Total" Binding="{Binding Amount, Converter={StaticResource CurrencyConverter}}" Width="120"/>
                    <controls:DataGridTextColumn Header="FBR" Binding="{Binding FbrStatus}" Width="100"/>
                    <controls:DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                </controls:DataGrid.Columns>
            </controls:DataGrid>
        </Border>

        <Rectangle Grid.Row="3" Height="1" HorizontalAlignment="Stretch" Fill="#E2E8F0" Margin="32,0"/>

        <!-- BOTTOM SECTION: Invoice Details -->
        <Border Grid.Row="4" Margin="60,16,60,40" Style="{StaticResource PremiumCardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#F9FAFB" Padding="20,12" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Items in Selection" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <ProgressRing IsActive="{x:Bind ViewModel.IsDetailsLoading, Mode=OneWay}" Width="16" Height="16" Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <controls:DataGrid Grid.Row="1" AutoGenerateColumns="False"
                                   ItemsSource="{x:Bind ViewModel.SelectedInvoiceItems}"
                                   GridLinesVisibility="Horizontal" HeadersVisibility="All"
                                   RowHeight="54" BorderThickness="0" Background="Transparent">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Medicine" Binding="{Binding MedicineName}" Width="*" IsReadOnly="True"/>
                        <controls:DataGridTextColumn Header="Qty Sold" Binding="{Binding Quantity}" Width="100" IsReadOnly="True"/>
                        <controls:DataGridTextColumn Header="Returned" Binding="{Binding ReturnedQuantity}" Width="100" IsReadOnly="True"/>
                        <controls:DataGridTextColumn Header="Remaining" Binding="{Binding RemainingQuantity}" Width="100" IsReadOnly="True"/>
                        <controls:DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, Converter={StaticResource CurrencyConverter}}" Width="100" IsReadOnly="True"/>
                        <controls:DataGridTextColumn Header="Total" Binding="{Binding CurrentTotal, Converter={StaticResource CurrencyConverter}}" Width="120" IsReadOnly="True"/>
                        
                        <controls:DataGridTemplateColumn Header="Return Qty" Width="100">
                            <controls:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:InvoiceItemViewModel">
                                    <TextBox Text="{x:Bind ReturnInputQty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="60" HorizontalAlignment="Center" FontSize="13" Height="32"/>
                                </DataTemplate>
                            </controls:DataGridTemplateColumn.CellTemplate>
                        </controls:DataGridTemplateColumn>

                        <controls:DataGridTemplateColumn Header="Action" Width="120">
                            <controls:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:InvoiceItemViewModel">
                                    <Button Content="Return" 
                                            Command="{Binding ElementName=PageRoot, Path=ViewModel.ExecuteReturnCommand}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{x:Bind CanReturn, Mode=OneWay}"
                                            Background="#EBF8FF" Foreground="#3182CE" FontWeight="SemiBold"
                                            Padding="12,4" FontSize="12" Height="32" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </controls:DataGridTemplateColumn.CellTemplate>
                        </controls:DataGridTemplateColumn>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>

                <!-- Empty State -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12"
                            Visibility="{x:Bind ViewModel.SelectedSale, Mode=OneWay, Converter={StaticResource EmptyToVisibilityConverter}}">
                    <FontIcon Glyph="&#xE990;" FontSize="48" Foreground="#CBD5E0"/>
                    <TextBlock Text="Select an invoice to view items and process returns" Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
