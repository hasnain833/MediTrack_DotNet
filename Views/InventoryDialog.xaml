<ContentDialog
    x:Class="DChemist.Views.InventoryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:DChemist.Models"
    mc:Ignorable="d"
    Title="Medicine Details"
    PrimaryButtonText="Save"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonStyle="{StaticResource PremiumButtonStyle}"
    SecondaryButtonStyle="{StaticResource SecondaryButtonStyle}"
    RequestedTheme="Dark"
    CornerRadius="16">
    
    <ContentDialog.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource GlassInputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassInputBorderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </ContentDialog.Resources>

    <StackPanel Spacing="16" Width="400" Margin="0,10,0,0">
        <StackPanel Spacing="6">
            <TextBlock Text="Medicine Name" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox x:Name="NameInput" PlaceholderText="e.g. Panadol 500mg"/>
        </StackPanel>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Spacing="6">
                <TextBlock Text="Dosage Form" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="DosageFormInput" PlaceholderText="e.g. Tablet"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock Text="Strength" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="StrengthInput" PlaceholderText="e.g. 500mg"/>
            </StackPanel>
        </Grid>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="6">
                <TextBlock Text="Selling Price" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                <NumberBox x:Name="SellingPriceInput" Value="0" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Compact"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock Text="Purchase Price" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                <NumberBox x:Name="PurchasePriceInput" Value="0" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Compact"/>
            </StackPanel>
        </Grid>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="6">
                <TextBlock Text="Expiry Date" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                <CalendarDatePicker x:Name="ExpiryInput" HorizontalAlignment="Stretch" PlaceholderText="Select date"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock Text="Quantity" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                <NumberBox x:Name="StockInput" Value="0" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Compact"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Spacing="6">
                <TextBlock Text="GST %" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                <NumberBox x:Name="GstInput" Value="0" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Compact"/>
            </StackPanel>
        </Grid>

        <StackPanel Spacing="6">
            <TextBlock Text="Supplier" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox x:Name="SupplierInput" PlaceholderText="e.g. GSK, Abbott"/>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Barcode / QR Code" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox x:Name="BarcodeInput" PlaceholderText="Scan or enter barcode"/>
        </StackPanel>


        
        <TextBlock x:Name="ErrorMessage" Foreground="Red" FontSize="12" Visibility="Collapsed" Margin="0,4,0,0"/>
    </StackPanel>
</ContentDialog>
