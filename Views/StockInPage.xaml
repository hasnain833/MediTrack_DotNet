<Page
    x:Class="DChemist.Views.StockInPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DChemist.ViewModels"
    xmlns:models="using:DChemist.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="PageRoot">

    <Grid Background="{ThemeResource AppBackgroundBrush}" RequestedTheme="Light" PointerPressed="PageRoot_PointerPressed">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════ Banner Header ═══════════════ -->
        <Border Background="{StaticResource PremiumBackgroundBrush}"
                CornerRadius="0,0,24,24" Padding="32,20" Margin="0,0,0,20">
            <Grid>
                <StackPanel Spacing="2">
                    <TextBlock Text="Inventory Stock In" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Select a medicine to receive stock and update batch pricing." FontSize="14" Foreground="#A0AEC0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="20">
                    <ToggleSwitch Header="Quick Scan (Auto-Add)" 
                                  IsOn="{x:Bind ViewModel.IsAutoAddEnabled, Mode=TwoWay}"
                                  FontSize="12" Foreground="White"
                                  OnContent="Auto-Add ON" OffContent="Auto-Add OFF"/>
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                               FontSize="13" FontWeight="SemiBold" Foreground="#A0AEC0"
                               MaxWidth="350" TextWrapping="Wrap" VerticalAlignment="Bottom"
                               TextAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════ Main Content ═══════════════ -->
        <Grid Grid.Row="1" Margin="24,0,24,24" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN: Unified Medicine Entry Form -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource PremiumCardStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Medicine Entry Form" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentAccent}"/>
                        
                        <!-- Core Medicine Details -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="Basic Information" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            
                            <TextBox x:Name="BarcodeReceiver" Header="Barcode (Optional)" HeaderTemplate="{StaticResource SmallHeader}"
                                     Text="{x:Bind ViewModel.BarcodeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="OnBarcodeKeyDown" PlaceholderText="Lookup barcode or leave empty…"/>

                            <AutoSuggestBox x:Name="MedicineNameBox"
                                            Header="Medicine Name" 
                                            Text="{x:Bind ViewModel.EntryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            ItemsSource="{x:Bind ViewModel.SearchSuggestions, Mode=OneWay}"
                                            SuggestionChosen="OnSuggestionChosen"
                                            DisplayMemberPath="Name" PlaceholderText="Type name…"/>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Header="Generic Name" HeaderTemplate="{StaticResource SmallHeader}"
                                         Text="{x:Bind ViewModel.EntryGeneric, Mode=TwoWay}" PlaceholderText="Paracetamol…"/>
                                <TextBox Grid.Column="1" Header="Dosage/Strength" HeaderTemplate="{StaticResource SmallHeader}"
                                         Text="{x:Bind ViewModel.EntryDosage, Mode=TwoWay}" PlaceholderText="500mg…"/>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Header="Category" HeaderTemplate="{StaticResource SmallHeader}"
                                          ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                                          DisplayMemberPath="Name"
                                          SelectedItem="{x:Bind ViewModel.EntryCategory, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"/>
                                <ComboBox Grid.Column="1" Header="Manufacturer" HeaderTemplate="{StaticResource SmallHeader}"
                                          ItemsSource="{x:Bind ViewModel.Manufacturers, Mode=OneWay}"
                                          DisplayMemberPath="Name"
                                          SelectedItem="{x:Bind ViewModel.EntryManufacturer, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"/>
                            </Grid>
                        </StackPanel>

                        <Border BorderThickness="0,1,0,0" BorderBrush="#E2E8F0" Margin="0,4"/>

                        <!-- Batch & Inventory Details -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="Batch &amp; Inventory" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Header="Batch Number" HeaderTemplate="{StaticResource SmallHeader}"
                                         Text="{x:Bind ViewModel.BatchNumber, Mode=TwoWay}" PlaceholderText="BN-1234…"/>
                                <CalendarDatePicker Grid.Column="1" Header="Expiry Date" HeaderTemplate="{StaticResource SmallHeader}"
                                                    Date="{x:Bind ViewModel.ExpiryDate, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                            </Grid>

                            <TextBox Header="Quantity (Units)" HeaderTemplate="{StaticResource SmallHeader}"
                                     Text="{x:Bind ViewModel.QuantityUnitsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <Border BorderThickness="0,1,0,0" BorderBrush="#E2E8F0" Margin="0,4"/>

                        <!-- Pricing Section -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="Pricing Details" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                            
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBox Header="Purchase TOTAL" HeaderTemplate="{StaticResource SmallHeader}"
                                             Text="{x:Bind ViewModel.PurchaseTotalPriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="{x:Bind ViewModel.PurchasePricePerUnitText, Mode=OneWay, Converter={StaticResource CurrencyConverter}, ConverterParameter='Unit: '}" 
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBox Header="Selling TOTAL" HeaderTemplate="{StaticResource SmallHeader}"
                                             Text="{x:Bind ViewModel.TotalSellingPriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="{x:Bind ViewModel.SellingPricePerUnitText, Mode=OneWay, Converter={StaticResource CurrencyConverter}, ConverterParameter='Unit: '}" 
                                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>

                            <Border Background="#F7FAFC" CornerRadius="8" Padding="12">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Profit Margin:" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind ViewModel.ProfitMarginText, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="Green" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Content="Add to List" 
                                            Command="{x:Bind ViewModel.AddToListCommand}"
                                            Style="{StaticResource PremiumButtonStyle}" 
                                            HorizontalAlignment="Right" Padding="24,4"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- RIGHT COLUMN: Batch Details & List -->
            <Grid Grid.Column="1" RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Batch & Supplier Info (Session Level) -->
                <Border Style="{StaticResource PremiumCardStyle}" Padding="20" Background="#EDF2F7">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Shipment &amp; Invoice Details" FontSize="15" FontWeight="Bold" Foreground="{StaticResource AccentAccent}"/>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="0">
                                <ComboBox ItemsSource="{x:Bind ViewModel.Suppliers, Mode=OneWay}"
                                          Header="Supplier Name" HeaderTemplate="{StaticResource SmallHeader}"
                                          DisplayMemberPath="Name"
                                          SelectedItem="{x:Bind ViewModel.SelectedSupplier, Mode=OneWay}"
                                          SelectionChanged="OnSupplierSelectionChanged"
                                          Text="{x:Bind ViewModel.SessionSupplierName, Mode=TwoWay}"
                                          IsEditable="True" HorizontalAlignment="Stretch" CornerRadius="8"/>
                            </StackPanel>

                            <TextBox Grid.Column="1" Header="Invoice #" HeaderTemplate="{StaticResource SmallHeader}"
                                     Text="{x:Bind ViewModel.SessionInvoiceNo, Mode=TwoWay}" CornerRadius="8"/>

                            <CalendarDatePicker Grid.Column="2" Header="Invoice Date" HeaderTemplate="{StaticResource SmallHeader}"
                                                Date="{x:Bind ViewModel.SessionInvoiceDate, Mode=TwoWay}" 
                                                HorizontalAlignment="Stretch" CornerRadius="8"/>
                        </Grid>
                    </StackPanel>
                </Border>


                <!-- Receiving List Table -->
                <Border Grid.Row="1" Style="{StaticResource PremiumCardStyle}" Padding="0" Margin="0,10,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#1A1A2E" CornerRadius="16,16,0,0" Padding="20,12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Medicine" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="Batch" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="Qty" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="Buy Total" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="4" Text="Buy Unit" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="5" Text="Sell Unit" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="6" Text="" />
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.ReceivingItems, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ReceivingItem">
                                        <Grid Padding="20,8" ColumnSpacing="12" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind MedicineName}" FontWeight="Bold" FontSize="12" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{x:Bind ExpiryDate, Converter={StaticResource DateFormatConverter}, ConverterParameter='EXP: {0:MMM yyyy}'}" FontSize="10" Foreground="#E53E3E"/>
                                            </StackPanel>
                                            
                                            <TextBlock Grid.Column="1" Text="{x:Bind BatchNo}" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{x:Bind QuantityUnits}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Grid.Column="3" Text="{x:Bind PurchaseTotalPrice, Converter={StaticResource CurrencyConverter}}" VerticalAlignment="Center" FontSize="11"/>
                                            <TextBlock Grid.Column="4" Text="{x:Bind UnitCost, Converter={StaticResource CurrencyConverter}}" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="5" Text="{x:Bind SellingPricePerUnit, Converter={StaticResource CurrencyConverter}}" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentAccent}"/>
                                            
                                            <Button Grid.Column="6" Command="{Binding ViewModel.RemoveItemCommand, ElementName=PageRoot}" CommandParameter="{Binding}" Style="{StaticResource TextBlockButtonStyle}" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE74D;" FontSize="13" Foreground="#E53E3E"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Footer Summary & Save -->
                <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20,12" BorderThickness="1" BorderBrush="#E2E8F0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="24">
                            <StackPanel>
                                <TextBlock Text="Total Items" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.ReceivingItems.Count, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Session Total Cost" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.GrandTotal, Mode=OneWay, Converter={StaticResource CurrencyConverter}}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Button HorizontalAlignment="Right" Command="{x:Bind ViewModel.SaveAllCommand}"
                                Style="{StaticResource PremiumButtonStyle}" Padding="40,10" CornerRadius="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                                <TextBlock Text="Complete Stock In" FontSize="15" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Width="60" Height="60" Foreground="{StaticResource AccentAccent}"
                      Canvas.ZIndex="100"/>
    </Grid>
</Page>
