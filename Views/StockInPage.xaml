<Page
    x:Class="DChemist.Views.StockInPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DChemist.ViewModels"
    xmlns:models="using:DChemist.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="PageRoot">

    <Grid Background="{ThemeResource AppBackgroundBrush}" RequestedTheme="Light" PointerPressed="PageRoot_PointerPressed" KeyDown="PageRoot_KeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════ Banner Header ═══════════════ -->
        <Border Background="{StaticResource PremiumBackgroundBrush}"
                CornerRadius="0,0,24,24" Padding="60,40" Margin="0,0,0,32">
            <Grid>
                <StackPanel Spacing="2">
                    <TextBlock Text="Inventory Stock In" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Select a medicine to receive stock and update batch pricing." FontSize="14" Foreground="#A0AEC0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="20">
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                               FontSize="14" FontWeight="SemiBold" Foreground="#A0AEC0"
                               MaxWidth="500" TextWrapping="Wrap" VerticalAlignment="Center"
                               TextAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════ Main Content ═══════════════ -->
        <Grid Grid.Row="1" Margin="48,0,48,48" ColumnSpacing="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN: Unified Medicine Entry Form -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="24" Padding="32">
                    <TextBlock Text="Medicine Information" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentAccent}"/>
                    
                    <!-- Medicine Details Section -->
                    <StackPanel Spacing="20">
                        <TextBox x:Name="BarcodeReceiver" Header="Barcode Scan" 
                                 Text="{x:Bind ViewModel.BarcodeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="OnBarcodeKeyDown" PlaceholderText="Ready for scanning..."/>

                        <AutoSuggestBox x:Name="MedicineNameBox"
                                        Header="Medicine Name" 
                                        Text="{x:Bind ViewModel.EntryName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        ItemsSource="{x:Bind ViewModel.SearchSuggestions, Mode=OneWay}"
                                        SuggestionChosen="OnSuggestionChosen"
                                        QuerySubmitted="OnMedicineQuerySubmitted"
                                        KeyDown="MedicineNameBox_KeyDown"
                                        DisplayMemberPath="Name" PlaceholderText="Type medicine name…"/>

                        <TextBox x:Name="GstBox" Header="GST %"
                                 HeaderTemplate="{StaticResource SmallHeader}"
                                 Text="{x:Bind ViewModel.EntryGstText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 PlaceholderText="e.g. 18" KeyDown="OnInputKeyDown"
                                 MaxLength="5"/>
                    </StackPanel>

                    <!-- Batch & Inventory Details -->
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="BatchNumberBox" Header="Batch Number" HeaderTemplate="{StaticResource SmallHeader}"
                                     Text="{x:Bind ViewModel.BatchNumber, Mode=TwoWay}" PlaceholderText="BN-1234…"
                                     KeyDown="OnInputKeyDown"/>
                            <TextBox x:Name="ExpiryDateBox" Grid.Column="1" Header="Expiry Date" HeaderTemplate="{StaticResource SmallHeader}"
                                     Text="{x:Bind ViewModel.ExpiryDateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     PlaceholderText="MMYY or MM/YYYY" HorizontalAlignment="Stretch"
                                     KeyDown="OnInputKeyDown"/>
                        </Grid>
                    </StackPanel>

                    <!-- Quantity & Unit Selection -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="Quantity Entry Mode" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        
                        <!-- Unit Mode Selector (Box, Packet, Tablet) -->
                        <Grid ColumnSpacing="4" Background="#EDF2F7" CornerRadius="8" Padding="4" Height="40">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <ToggleButton Content="Box" x:Name="BoxModeBtn"
                                          IsChecked="{x:Bind ViewModel.IsBoxMode, Mode=OneWay}"
                                          Click="OnModeChanged" KeyDown="OnModeKeyDown" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                          Style="{StaticResource SegmentedButtonStyle}"/>
                            <ToggleButton Grid.Column="1" Content="Packet" x:Name="PacketModeBtn"
                                          IsChecked="{x:Bind ViewModel.IsPacketMode, Mode=OneWay}"
                                          Click="OnModeChanged" KeyDown="OnModeKeyDown" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                          Style="{StaticResource SegmentedButtonStyle}"/>
                            <ToggleButton Grid.Column="2" Content="Tablet" x:Name="TabletModeBtn"
                                          IsChecked="{x:Bind ViewModel.IsTabletMode, Mode=OneWay}"
                                          Click="OnModeChanged" KeyDown="OnModeKeyDown" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                          Style="{StaticResource SegmentedButtonStyle}"/>
                        </Grid>

                        <!-- Dynamic Inputs based on Mode -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Case 1: Box/Packet Mode (Show Units per Pack + Number of Packs) -->
                            <TextBox Header="{x:Bind BoxModeBtn.IsChecked, Mode=OneWay, Converter={StaticResource StringToHeaderConverter}, ConverterParameter='Tablets per Box|Tablets per Packet'}" 
                                     Visibility="{x:Bind ViewModel.IsTabletMode, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                     Text="{x:Bind ViewModel.UnitsPerPackText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="e.g. 100" KeyDown="OnInputKeyDown"
                                     x:Name="UnitsPerPackBox"/>

                            <TextBox Grid.Column="1" 
                                     Header="{x:Bind BoxModeBtn.IsChecked, Mode=OneWay, Converter={StaticResource StringToHeaderConverter}, ConverterParameter='Number of Boxes|Number of Packets'}"
                                     Visibility="{x:Bind ViewModel.IsTabletMode, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                     Text="{x:Bind ViewModel.PackQuantityText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="e.g. 10" KeyDown="OnInputKeyDown"
                                     x:Name="PackQuantityBox"/>

                            <!-- Case 2: Tablet Mode (Show Simple Quantity) -->
                            <TextBox Grid.ColumnSpan="2" Header="Quantity (Total Tablets)"
                                     Visibility="{x:Bind ViewModel.IsTabletMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     Text="{x:Bind ViewModel.QuantityUnitsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="OnInputKeyDown"
                                     x:Name="QuantityBox"/>
                        </Grid>

                        <!-- Calculation Preview -->
                        <TextBlock Text="{x:Bind ViewModel.TotalUnitsPreviewText, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.IsTabletMode, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                   FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentAccent}" HorizontalAlignment="Right" Margin="0,-4,0,0"/>

                    </StackPanel>

                    <!-- Pricing Section -->
                    <StackPanel Spacing="12">
                       <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBox x:Name="PurchaseTotalBox" Header="Purchase TOTAL" HeaderTemplate="{StaticResource SmallHeader}"
                                         Text="{x:Bind ViewModel.PurchaseTotalPriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="OnInputKeyDown"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBox x:Name="SellingTotalBox" Header="Selling TOTAL" HeaderTemplate="{StaticResource SmallHeader}"
                                         Text="{x:Bind ViewModel.TotalSellingPriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="OnInputKeyDown"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="#F0F4F8" CornerRadius="12" Padding="16">
                            <Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Profit Margin" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.ProfitMarginText, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="Green"/>
                                </StackPanel>
                                <Button x:Name="AddToListButton" Content="Add to List" 
                                        Command="{x:Bind ViewModel.AddToListCommand}"
                                        Style="{StaticResource PremiumButtonStyle}" 
                                        HorizontalAlignment="Right" Padding="32,12"
                                        KeyDown="OnInputKeyDown"
                                        CornerRadius="8"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT COLUMN: Batch Details & List -->
            <Grid Grid.Column="1" RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Batch & Supplier Info (Session Level) -->
                <Border Style="{StaticResource PremiumCardStyle}" Padding="20" Background="#EDF2F7">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Shipment &amp; Invoice Details" FontSize="15" FontWeight="Bold" Foreground="{StaticResource AccentAccent}"/>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="0">
                                <ComboBox ItemsSource="{x:Bind ViewModel.Suppliers, Mode=OneWay}"
                                          Header="Supplier Name" HeaderTemplate="{StaticResource SmallHeader}"
                                          DisplayMemberPath="Name"
                                          SelectedItem="{x:Bind ViewModel.SelectedSupplier, Mode=OneWay}"
                                          SelectionChanged="OnSupplierSelectionChanged"
                                          Text="{x:Bind ViewModel.SessionSupplierName, Mode=TwoWay}"
                                          IsEditable="True" HorizontalAlignment="Stretch" CornerRadius="8"/>
                            </StackPanel>

                            <TextBox Grid.Column="1" Header="Invoice #" HeaderTemplate="{StaticResource SmallHeader}"
                                     Text="{x:Bind ViewModel.SessionInvoiceNo, Mode=TwoWay}" CornerRadius="8"/>

                            <CalendarDatePicker Grid.Column="2" Header="Invoice Date" HeaderTemplate="{StaticResource SmallHeader}"
                                                Date="{x:Bind ViewModel.SessionInvoiceDate, Mode=TwoWay}" 
                                                HorizontalAlignment="Stretch" CornerRadius="8"/>
                        </Grid>
                    </StackPanel>
                </Border>


                <!-- Receiving List Table -->
                <Border Grid.Row="1" Style="{StaticResource PremiumCardStyle}" Padding="0" Margin="0,10,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#1A1A2E" CornerRadius="16,16,0,0" Padding="20,12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Medicine" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="Batch" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="Qty" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="Buy Total" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="4" Text="Buy Unit" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="5" Text="Sell Unit" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="6" Text="" />
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.ReceivingItems, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ReceivingItem">
                                        <Grid Padding="20,8" ColumnSpacing="12" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind MedicineName}" FontWeight="Bold" FontSize="12" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            
                                            <TextBlock Grid.Column="1" Text="{x:Bind BatchNo}" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{x:Bind QuantityUnits}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Grid.Column="3" Text="{x:Bind PurchaseTotalPrice, Converter={StaticResource CurrencyConverter}}" VerticalAlignment="Center" FontSize="11"/>
                                            <TextBlock Grid.Column="4" Text="{x:Bind UnitCost, Converter={StaticResource CurrencyConverter}}" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="5" Text="{x:Bind SellingPricePerUnit, Converter={StaticResource CurrencyConverter}}" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentAccent}"/>
                                            
                                            <Button Grid.Column="6" Command="{Binding ViewModel.RemoveItemCommand, ElementName=PageRoot}" CommandParameter="{Binding}" Style="{StaticResource TextBlockButtonStyle}" HorizontalAlignment="Center">
                                                <FontIcon Glyph="&#xE74D;" FontSize="13" Foreground="#E53E3E"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Footer Summary & Save -->
                <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="32,20" BorderThickness="1" BorderBrush="#E2E8F0" Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Orientation="Horizontal" Spacing="40" VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Total Items" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.ReceivingItems.Count, Mode=OneWay}" FontSize="24" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Session Total Cost" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.GrandTotal, Mode=OneWay, Converter={StaticResource CurrencyConverter}}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentAccent}"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Button Grid.Column="1" Command="{x:Bind ViewModel.SaveAllCommand}"
                                Style="{StaticResource PremiumButtonStyle}" Padding="60,16" CornerRadius="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE74E;" FontSize="18"/>
                                <TextBlock Text="Complete Stock In" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Width="60" Height="60" Foreground="{StaticResource AccentAccent}"
                      Canvas.ZIndex="100"/>
    </Grid>
</Page>
