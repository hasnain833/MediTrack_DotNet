<Page
    x:Class="MediTrack.Views.BillingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:vm="using:MediTrack.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Cart & Search -->
        <Grid Padding="0,0,32,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="New Bill Generation" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,24"/>

            <StackPanel Grid.Row="1" Spacing="12" Margin="0,0,0,24">
                <AutoSuggestBox Header="Search Medicine" PlaceholderText="Type medicine name..."
                                Text="{x:Bind ViewModel.SearchMedicineText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                QueryIcon="Find" ItemsSource="{x:Bind ViewModel.MedicineResults}"
                                x:Name="MedicineSearchBox">
                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="20">
                                <TextBlock Text="{Binding MedicineName}" FontWeight="SemiBold" Width="200"/>
                                <TextBlock Text="{Binding Category}" Opacity="0.6" Width="100"/>
                                <TextBlock Text="{Binding Price, Converter={StaticResource CurrencyConverter}}" Foreground="{ThemeResource AccentAAFillColorDefaultBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                </AutoSuggestBox>
                <Button Content="Add to Cart" Command="{x:Bind ViewModel.AddToCartCommand}" 
                        Style="{StaticResource PremiumButtonStyle}" HorizontalAlignment="Right"/>
            </StackPanel>

            <controls:DataGrid Grid.Row="2" AutoGenerateColumns="False"
                               ItemsSource="{x:Bind ViewModel.CartItems}"
                               GridLinesVisibility="Horizontal" HeadersVisibility="All"
                               RowHeight="48" BorderThickness="0">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Medicine" Binding="{Binding MedicineName}" Width="*"/>
                    <controls:DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, Converter={StaticResource CurrencyConverter}}" Width="100"/>
                    <controls:DataGridTemplateColumn Header="Qty" Width="100">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:SaleItemViewModel">
                                <TextBox Text="{x:Bind Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                         HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="4"/>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>
                    <controls:DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, Converter={StaticResource CurrencyConverter}}" Width="120"/>
                </controls:DataGrid.Columns>
            </controls:DataGrid>
        </Grid>

        <!-- Right: Summary & Customer -->
        <Border Grid.Column="1" Background="#F9F9F9" CornerRadius="12" Padding="24">
            <StackPanel Spacing="24">
                <TextBlock Text="Customer Information" FontSize="16" FontWeight="SemiBold"/>
                <TextBox Header="Customer Name" Text="{x:Bind ViewModel.CustomerName, Mode=TwoWay}"/>
                <TextBox Header="Phone Number" Text="{x:Bind ViewModel.CustomerPhone, Mode=TwoWay}"/>

                <Border Height="1" Background="#E0E0E0"/>

                <TextBlock Text="Order Summary" FontSize="16" FontWeight="SemiBold"/>
                <Grid>
                    <StackPanel Spacing="12">
                        <Grid>
                            <TextBlock Text="Subtotal" Foreground="#666666"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalAmount, Mode=OneWay, Converter={StaticResource CurrencyConverter}}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Tax (18%)" Foreground="#666666"/>
                            <TextBlock Text="{x:Bind ViewModel.TaxAmount, Mode=OneWay, Converter={StaticResource CurrencyConverter}}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Discount" Foreground="#666666"/>
                            <TextBox Text="{x:Bind ViewModel.DiscountAmount, Mode=TwoWay}" Width="100" HorizontalAlignment="Right" TextAlignment="Right"/>
                        </Grid>
                        <Border Height="1" Background="#E0E0E0" Margin="0,12"/>
                        <Grid>
                            <TextBlock Text="Grand Total" FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="{x:Bind ViewModel.GrandTotal, Mode=OneWay, Converter={StaticResource CurrencyConverter}}" 
                                       FontSize="18" FontWeight="Bold" Foreground="{ThemeResource AccentAAFillColorDefaultBrush}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <Button Content="COMPLETE SALE" Command="{x:Bind ViewModel.CompleteSaleCommand}"
                        Style="{StaticResource PremiumButtonStyle}" Height="50" HorizontalAlignment="Stretch"
                        Margin="0,20,0,0"/>
                
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
