<Page
    x:Class="DChemist.Views.BillingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DChemist.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="PageRoot">

    <Grid Background="{ThemeResource AppBackgroundBrush}" RequestedTheme="Light" KeyDown="PageRoot_KeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Banner -->
        <Border Background="{StaticResource PremiumBackgroundBrush}"
                CornerRadius="0,0,24,24" Padding="40,28" Margin="0,0,0,24">
            <StackPanel Spacing="6">
                <TextBlock Text="Billing" FontSize="32" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Create sales, scan items and generate receipts." FontSize="15" Foreground="#A0AEC0"/>
            </StackPanel>
        </Border>

        <!-- Main two-column layout -->
        <Grid Grid.Row="1" Background="{ThemeResource AppBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

        <!-- Left: Bill Generation -->
        <Grid Padding="40,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title and Add Button -->

                <!-- Unified Search & Scanner Card -->
                <Border Grid.Row="1" Style="{StaticResource PremiumCardStyle}" Padding="20,16" Margin="0,0,16,20" Background="{ThemeResource AppBackgroundBrush}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="Continuous Scan" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                            <ToggleButton x:Name="ContinuousScanToggle"
                                          Content="OFF" 
                                          IsChecked="{x:Bind ViewModel.IsContinuousScanMode, Mode=TwoWay}"
                                          Checked="ContinueusScanToggle_Checked"
                                          Unchecked="ContinueusScanToggle_Unchecked"
                                          CornerRadius="8" 
                                          Height="36" />
                        </StackPanel>


                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Search Local Stock" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                <AutoSuggestBox x:Name="MedicineSearchBox"
                                                PlaceholderText="Type medicine name..."
                                                QueryIcon="Find"
                                                TextMemberPath="Name"
                                                Text="{x:Bind ViewModel.SearchMedicineText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                ItemsSource="{x:Bind ViewModel.MedicineResults, Mode=OneWay}"
                                                QuerySubmitted="MedicineSearchBox_QuerySubmitted"
                                                CornerRadius="8" Height="36">
                                    <AutoSuggestBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="4,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="110"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding CategoryName}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Price, Converter={StaticResource CurrencyConverter}}"
                                                           Foreground="{StaticResource AccentAccent}"
                                                           HorizontalAlignment="Right" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </AutoSuggestBox.ItemTemplate>
                                </AutoSuggestBox>
                            </StackPanel>
                            <ProgressRing IsActive="{x:Bind ViewModel.IsSearching, Mode=OneWay}"
                                          Width="20" Height="20" HorizontalAlignment="Right" 
                                          Margin="0,20,40,0" VerticalAlignment="Center"
                                          Foreground="{StaticResource AccentAccent}"/>
                        </Grid>
                    </Grid>
                </Border>

            <!-- Cart Table -->
            <Border Grid.Row="2" Style="{StaticResource PremiumCardStyle}" Padding="0" Margin="0,0,16,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Static Table Header (non-interactive) -->
                    <Grid Background="#1A1A2E" CornerRadius="12,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Medicine" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" Margin="16,12"/>
                        <TextBlock Grid.Column="1" Text="Price (Unit)" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" Margin="4,12"/>
                        <TextBlock Grid.Column="2" Text="Qty" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" Margin="4,12"/>
                        <TextBlock Grid.Column="3" Text="Subtotal" Foreground="White" FontWeight="SemiBold"
                                   FontSize="13" HorizontalAlignment="Right" Margin="0,12,16,12"/>
                        <TextBlock Grid.Column="4" Text="" Margin="0,12,16,12"/>
                    </Grid>

                    <!-- Cart Items (real data) + sample rows shown when cart is empty -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Live cart items -->
                            <ItemsControl ItemsSource="{x:Bind ViewModel.CartItems, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SaleItemViewModel">
                                        <Grid Padding="16,0" MinHeight="54"
                                              BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Medicine Name -->
                                            <TextBlock Text="{x:Bind MedicineName}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="Medium" VerticalAlignment="Center"/>
                                            <!-- Effective unit price -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind UnitPrice, Converter={StaticResource CurrencyConverter}, Mode=OneWay}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="4,0" FontSize="13"/>
                                            <!-- Quantity -->
                                            <NumberBox Grid.Column="2"
                                                       Value="{x:Bind Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       SpinButtonPlacementMode="Compact"
                                                       SmallChange="1"
                                                       LargeChange="5"
                                                       HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                       Margin="2,8"/>
                                            <!-- Subtotal -->
                                            <TextBlock Grid.Column="3"
                                                       Text="{x:Bind Subtotal, Converter={StaticResource CurrencyConverter}, Mode=OneWay}"
                                                       Foreground="{StaticResource AccentAccent}"
                                                       FontWeight="SemiBold" HorizontalAlignment="Right"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <!-- Remove -->
                                            <Button Grid.Column="4" 
                                                    Command="{Binding ViewModel.RemoveFromCartCommand, ElementName=PageRoot}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource TextBlockButtonStyle}" 
                                                    Padding="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#E53E3E"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Right: Customer Info + Order Summary -->
        <Border Grid.Column="1" Style="{StaticResource PremiumCardStyle}" Margin="0,0,0,0" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                <StackPanel Spacing="24" Padding="20">
                <!-- Customer Information -->
                <StackPanel Spacing="16">
                    <TextBlock Text="Customer Information" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Customer Name" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Text="{x:Bind ViewModel.CustomerName, Mode=TwoWay}"
                                 PlaceholderText="Internal Sale"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Phone Number" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Text="{x:Bind ViewModel.CustomerPhone, Mode=TwoWay}"
                                 PlaceholderText="Optional"/>
                    </StackPanel>
                </StackPanel>

                <Border Height="1" Background="#F0F0F0"/>

                <!-- Order Summary -->
                <StackPanel Spacing="16">
                    <TextBlock Text="Order Summary" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <Grid>
                        <TextBlock Text="Subtotal" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium"/>
                        <TextBlock Text="{x:Bind ViewModel.TotalAmount, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                   HorizontalAlignment="Right" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid Visibility="{x:Bind ViewModel.TaxAmount, Mode=OneWay, Converter={StaticResource DecimalToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind ViewModel.TaxRateText, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium"/>
                        <TextBlock Text="{x:Bind ViewModel.TaxAmount, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                   HorizontalAlignment="Right" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="Discount (%)" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Medium"/>
                            <TextBlock Text="{x:Bind ViewModel.DiscountAmount, Mode=OneWay, Converter={StaticResource CurrencyConverter}}" 
                                       FontSize="10" Foreground="{StaticResource AccentAccent}" FontWeight="Bold" 
                                       VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </StackPanel>
                        <TextBox Text="{x:Bind ViewModel.DiscountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="0"
                                 Width="80" HorizontalAlignment="Right" TextAlignment="Right"/>
                    </Grid>

                    <Border Height="1" Background="#F0F0F0" Margin="0,8"/>

                    <Grid>
                        <TextBlock Text="Grand Total" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.GrandTotal, Mode=OneWay, Converter={StaticResource CurrencyConverter}}"
                                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentAccent}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>

                <Border Height="1" Background="#F0F0F0"/>

                <!-- Actions -->
                <StackPanel Spacing="10">
                    <Button Content="Print" 
                            Command="{x:Bind ViewModel.CompleteSaleReportedCommand}"
                            Style="{StaticResource PremiumButtonStyle}" Height="54"
                            HorizontalAlignment="Stretch" FontSize="14" FontWeight="Bold"/>

                    <Button Content="SAVE INTERNALLY" 
                            Command="{x:Bind ViewModel.CompleteSaleInternalCommand}"
                            Style="{StaticResource PremiumButtonStyle}" Height="54"
                            Background="#4A5568"
                            HorizontalAlignment="Stretch" FontSize="14" FontWeight="Bold"/>

                    <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                  Foreground="{StaticResource AccentAccent}" HorizontalAlignment="Center"
                                  Width="24" Height="24" Margin="0,4,0,0"/>

                    <!-- Stock / error feedback — hidden when empty -->
                    <Border Background="{x:Bind ViewModel.IsStatusSuccess, Mode=OneWay, Converter={StaticResource StatusBgConverter}}" 
                            CornerRadius="8" Padding="12,8"
                            Visibility="{x:Bind ViewModel.StatusMessage, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                   TextWrapping="Wrap" 
                                   Foreground="{x:Bind ViewModel.IsStatusSuccess, Mode=OneWay, Converter={StaticResource StatusFgConverter}}" 
                                   FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
        </Grid><!-- end inner two-column layout -->

        <!-- Hidden Barcode Receiver for Pos Scanning -->
        <TextBox x:Name="BarcodeReceiver" 
                 Width="0" Height="0" Opacity="0"
                 Text="{x:Bind ViewModel.BarcodeText, Mode=TwoWay}"
                 KeyDown="HiddenBarcodeReceiver_KeyDown"/>
    </Grid>
</Page>
