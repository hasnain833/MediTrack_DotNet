<Page
    x:Class="MediTrack.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MediTrack.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="32">
            <!-- Grid for Metric Cards -->
            <GridView ItemsSource="{x:Bind ViewModel.Metrics}" SelectionMode="None">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="vm:MetricItem">
                        <Grid Width="260" Height="140" Margin="0,0,16,16">
                            <Border Background="White" CornerRadius="12" Padding="20" BorderThickness="1" BorderBrush="#EAEAEA">
                                <Grid>
                                    <StackPanel Spacing="4" VerticalAlignment="Top">
                                        <TextBlock Text="{x:Bind Title}" Foreground="#666666" FontSize="13"/>
                                        <TextBlock Text="{x:Bind Value}" FontSize="24" FontWeight="Bold" Foreground="#222222"/>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="40" Height="40" 
                                            Background="#F0F5FF" CornerRadius="8">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="{x:Bind Icon}" 
                                                  Foreground="#1E3C72" FontSize="18"/>
                                    </Border>
                                    <TextBlock Text="{x:Bind Trend}" VerticalAlignment="Bottom" FontSize="11"
                                               Foreground="{x:Bind Positive, Converter={StaticResource PositiveToColorConverter}}"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Bottom Section: Recent Activity -->
            <Grid Padding="0,0,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24" Margin="0,0,16,0">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Recent Activity" FontSize="18" FontWeight="SemiBold"/>
                        <ListView ItemsSource="{x:Bind ViewModel.RecentActivities}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,8">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <Ellipse Width="8" Height="8" Fill="{ThemeResource AccentAAFillColorDefaultBrush}"/>
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{ThemeResource PremiumBackgroundBrush}" CornerRadius="12" Padding="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="System Health" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <StackPanel Spacing="20">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Database Connection" Foreground="#AAFFFFFF" FontSize="12"/>
                                <TextBlock Text="Stable" Foreground="White" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Backup Service" Foreground="#AAFFFFFF" FontSize="12"/>
                                <TextBlock Text="Active (2h ago)" Foreground="White" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
