<Page
    x:Class="MediTrack.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:MediTrack.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="32">
            <!-- Grid for Metric Cards -->
            <GridView ItemsSource="{x:Bind ViewModel.Metrics}" SelectionMode="None">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="vm:MetricItem">
                        <Grid Width="280" Height="140" Margin="0,0,16,16">
                            <Border Style="{StaticResource PremiumCardStyle}">
                                <Grid>
                                    <StackPanel Spacing="6" VerticalAlignment="Top">
                                        <TextBlock Text="{x:Bind Title}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontWeight="Medium"/>
                                        <TextBlock Text="{x:Bind Value}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="44" Height="44" 
                                            Background="#F0F7FF" CornerRadius="10">
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="{x:Bind Icon}" 
                                                  Foreground="{StaticResource AccentAccent}" FontSize="20"/>
                                    </Border>
                                    <TextBlock Text="{x:Bind Trend}" VerticalAlignment="Bottom" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{x:Bind Positive, Converter={StaticResource PositiveToColorConverter}}"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Bottom Section: Recent Activity -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PremiumCardStyle}" Margin="0,0,16,0">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Recent Activity" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ListView ItemsSource="{x:Bind ViewModel.RecentActivities}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,12" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <FontIcon Glyph="&#xE91F;" FontSize="12" Foreground="{StaticResource AccentAccent}"/>
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource SidebarBackgroundBrush}" CornerRadius="12" Padding="24">
                    <StackPanel Spacing="24">
                        <TextBlock Text="System Health" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <StackPanel Spacing="20">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Database Connection" Foreground="#88FFFFFF" FontSize="12" FontWeight="Medium"/>
                                <TextBlock Text="Stable" Foreground="White" FontWeight="Bold" FontSize="16"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Backup Service" Foreground="#88FFFFFF" FontSize="12" FontWeight="Medium"/>
                                <TextBlock Text="Active (2h ago)" Foreground="White" FontWeight="Bold" FontSize="16"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
