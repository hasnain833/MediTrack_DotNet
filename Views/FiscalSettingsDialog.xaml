<ContentDialog
    x:Class="DChemist.Views.FiscalSettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="FBR Fiscal Settings"
    PrimaryButtonText="Save"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary">

    <ContentDialog.Resources>
        <Style x:Key="DarkInputStyle" TargetType="Control">
            <Setter Property="Background" Value="#2D3748"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource DarkInputStyle}">
            <Setter Property="PlaceholderForeground" Value="#A0AEC0"/>
        </Style>
        <Style TargetType="PasswordBox" BasedOn="{StaticResource DarkInputStyle}">
        </Style>
    </ContentDialog.Resources>

    <StackPanel Spacing="16" Width="400">
        <TextBlock Text="Configure your real-time FBR reporting settings." 
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>

        <ToggleSwitch x:Name="IsLiveToggle" Header="Live FBR Mode" 
                      OffContent="Simulator (Mock)" OnContent="Live (FBR IMS API)"/>

        <StackPanel Spacing="6">
            <TextBlock Text="FBR POS ID" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox x:Name="PosIdInput" PlaceholderText="e.g. 123456-789"/>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="API Endpoint URL" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBox x:Name="ApiUrlInput" PlaceholderText="https://ims.fbr.gov.pk/..."/>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Access Token" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
            <PasswordBox x:Name="TokenInput" PlaceholderText="Enter FBR API Token"/>
        </StackPanel>
        
        <TextBlock x:Name="ErrorMessage" Foreground="Red" FontSize="12" Visibility="Collapsed"/>
    </StackPanel>
</ContentDialog>
