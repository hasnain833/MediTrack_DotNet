<Page
    x:Class="MediTrack.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MediTrack.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource PremiumBackgroundBrush}">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="50" IsStaggeringEnabled="True"/>
            </TransitionCollection>
        </Grid.ChildrenTransitions>

        <Border Width="480" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="White" CornerRadius="24" Padding="54" Margin="24">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <StackPanel Spacing="36">
                <!-- Branding Section -->
                <StackPanel Spacing="12">
                    <TextBlock Text="D. Chemist" FontSize="44" FontWeight="ExtraBold" 
                               HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI Variable Display"/>
                    <TextBlock Text="PREMIUM MEDICAL MANAGEMENT" FontSize="11" FontWeight="Bold"
                               CharacterSpacing="200" Foreground="{StaticResource TextSecondaryBrush}" 
                               HorizontalAlignment="Center" Opacity="0.8"/>
                </StackPanel>

                <!-- Input Section -->
                <StackPanel Spacing="28">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Username" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="2,0"/>
                        <TextBox PlaceholderText="Enter your username"
                                 Text="{x:Bind ViewModel.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="44"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Password" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="2,2"/>
                        <PasswordBox PlaceholderText="Enter your password"
                                     Password="{x:Bind ViewModel.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Height="44"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action Section -->
                <StackPanel Spacing="24">
                    <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" 
                               Foreground="#EF4444" 
                               FontSize="13"
                               Visibility="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               FontWeight="Medium"/>

                    <Button Content="SIGN IN TO DASHBOARD" 
                            Command="{x:Bind ViewModel.LoginCommand}" 
                            Style="{StaticResource PremiumButtonStyle}"
                            Height="48"
                            CornerRadius="10"/>
                    
                    <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" 
                                  Foreground="{StaticResource AccentAccent}"
                                  HorizontalAlignment="Center" Width="28" Height="28"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
