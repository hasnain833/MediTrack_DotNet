<ContentDialog
    x:Class="DChemist.Views.ChangePasswordDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Security: Password Change Required"
    PrimaryButtonText="Update Password"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <StackPanel Spacing="16" Margin="0,10,0,0">
        <TextBlock Text="For security reasons, you must change your password before continuing." 
                   TextWrapping="Wrap" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
        
        <StackPanel Spacing="6">
            <TextBlock Text="New Password" FontSize="12" FontWeight="SemiBold"/>
            <PasswordBox x:Name="NewPasswordField" PlaceholderText="Min 6 characters"/>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Confirm New Password" FontSize="12" FontWeight="SemiBold"/>
            <PasswordBox x:Name="ConfirmPasswordField" PlaceholderText="Repeat password"/>
        </StackPanel>

        <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="12" Visibility="Collapsed"/>
    </StackPanel>
</ContentDialog>
