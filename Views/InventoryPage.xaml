<Page
    x:Class="MediTrack.Views.InventoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:vm="using:MediTrack.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource AppBackgroundBrush}" Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PremiumCardStyle}" Margin="0,0,0,24">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <AutoSuggestBox PlaceholderText="Search medicines..." 
                                    Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    QueryIcon="Find" Width="450"/>
                    <Button Command="{x:Bind ViewModel.RefreshCommand}" 
                            Style="{StaticResource TextBlockButtonStyle}" VerticalAlignment="Center" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE72C;" FontSize="16" Foreground="{StaticResource AccessKeySecondaryForeground}"/>
                            <TextBlock Text="Refresh" VerticalAlignment="Center" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <Button Content="Add Medicine" Style="{StaticResource PremiumButtonStyle}"
                        HorizontalAlignment="Right" Width="180"
                        Visibility="{x:Bind ViewModel.IsAdmin, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PremiumCardStyle}" Padding="0">
            <controls:DataGrid AutoGenerateColumns="False"
                               ItemsSource="{x:Bind ViewModel.Medicines, Mode=OneWay}"
                               IsReadOnly="True"
                               GridLinesVisibility="Horizontal"
                               HeadersVisibility="All"
                               RowHeight="54"
                               BorderThickness="0"
                               Background="Transparent">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Medicine Name" Binding="{Binding MedicineName}" Width="*"/>
                    <controls:DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="150"/>
                    <controls:DataGridTextColumn Header="Price" Binding="{Binding Price, Converter={StaticResource CurrencyConverter}}" Width="120"/>
                    <controls:DataGridTextColumn Header="Stock" Binding="{Binding StockQty}" Width="100"/>
                    <controls:DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate, Converter={StaticResource DateConverter}}" Width="150"/>
                </controls:DataGrid.Columns>
            </controls:DataGrid>
        </Border>

        <ProgressRing Grid.Row="1" IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" 
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Foreground="{StaticResource AccentAccent}" Width="40" Height="40"/>
    </Grid>
</Page>
