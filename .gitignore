## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bin/
obj/
Bin/
Obj/
**/bin/
**/obj/
**/x64/
**/x86/

# Visual Studio 2015/2017 cache/options directory
.vs/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent-conformance.log

# Build logs
*.log

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*.obj
*.exe
*.pdb
*.user
*.aps
*.pch
*.vspscc
*.vssscc
*_i.c
*_p.c
*.ncb
*.suo
*.tlb
*.tlh
*.bak
*.cache
*.ilk
*.log
*.lib
*.sbr
*.sdf
*.opensdf
*.zip
*.vshost.exe
*.vshost.exe.config
*.vshost.exe.manifest
*.manifest
*.res
*.rc2
*.rc.bak
*.rc.res
*.db
*.opendb

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/

# Better to ignore the whole artifacts directory if using new SDK-style projects
artifacts/

# JetBrains Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustCode
.JustCode

# TeamCity
_TeamCity*

# Omono
.omono

# Visual Studio Code
.vscode/
.history
*.code-workspace

# Windows Specific
Thumbs.db
ehthumbs.db
Desktop.ini

# WinUI 3 Specific
AppPackages/
BundleArtifacts/
