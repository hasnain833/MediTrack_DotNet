<Application
    x:Class="MediTrack.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MediTrack"
    xmlns:utils="using:MediTrack.Utils"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
    xmlns:ui="using:Microsoft.UI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///CommunityToolkit.WinUI.UI.Controls.DataGrid/DataGrid/DataGrid.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <!-- Keep all input states white with dark text -->
                    <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White"/>
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="#F3F4F6"/>
                    <SolidColorBrush x:Key="TextControlForeground" Color="#111827"/>
                    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#111827"/>
                    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#111827"/>
                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#9CA3AF"/>
                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#6B7280"/>
                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#9CA3AF"/>
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#E0E0E0"/>
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#9CA3AF"/>
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#00D2FF"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <!-- Keep all input states white with dark text -->
                    <SolidColorBrush x:Key="TextControlBackground" Color="White"/>
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="White"/>
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="White"/>
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="#F3F4F6"/>
                    <SolidColorBrush x:Key="TextControlForeground" Color="#111827"/>
                    <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#111827"/>
                    <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#111827"/>
                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#9CA3AF"/>
                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#6B7280"/>
                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#9CA3AF"/>
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#E0E0E0"/>
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#9CA3AF"/>
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#00D2FF"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- 2. Converters -->
            <utils:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <utils:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <utils:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <utils:CurrencyConverter x:Key="CurrencyConverter"/>
            <utils:DateConverter x:Key="DateConverter"/>
            <utils:PositiveToColorConverter x:Key="PositiveToColorConverter"/>

            <!-- 3. Brushes (Dependent on Tokens) -->
            <SolidColorBrush x:Key="AccentAccent" Color="#00D2FF"/>
            
            <LinearGradientBrush x:Key="PremiumBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0A1628" Offset="0.0" />
                <GradientStop Color="#0D2137" Offset="0.4" />
                <GradientStop Color="#0A2A4A" Offset="0.75" />
                <GradientStop Color="#0D3347" Offset="1.0" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="PremiumAccentBrush" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#00D2FF" Offset="0.0" />
                <GradientStop Color="#3a7bd5" Offset="1.0" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="GlassCardBrush" Color="#25FFFFFF"/>
            <SolidColorBrush x:Key="GlassBorderBrush" Color="#40FFFFFF"/>
            <SolidColorBrush x:Key="GlassInputBrush" Color="#15FFFFFF"/>
            <SolidColorBrush x:Key="GlassInputBorderBrush" Color="#30FFFFFF"/>
            <SolidColorBrush x:Key="TextOnGlassBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="TextOnGlassSecondaryBrush" Color="#B0D4E8"/>

            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111827"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#4B5563"/>
            <SolidColorBrush x:Key="TextOnAccentBrush" Color="White"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="White"/>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F8F9FA"/>
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#22333B"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>

            <!-- 4. Styles (Dependent on Brushes) -->
            <Style x:Key="GlassBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Shadow">
                    <Setter.Value>
                        <ThemeShadow />
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Card Styling -->
            <Style x:Key="PremiumCardStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="BorderBrush" Value="#F0F0F0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Margin" Value="0,0,16,16"/>
            </Style>

            <!-- Premium Button Styling -->
            <Style x:Key="PremiumButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource PremiumAccentBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="24,10"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource AccentAccent}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AccentAccent}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="24,10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
            </Style>

            <Style x:Key="SidebarItemStyle" TargetType="ListViewItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#A0AEC0"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Margin" Value="0,2"/>
                <Setter Property="Padding" Value="0"/>
            </Style>

            <!-- Global DataGrid Styles -->
            <Style TargetType="controls:DataGrid">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="AlternatingRowBackground" Value="#FBFCFD"/>
                <Setter Property="RowBackground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <Style TargetType="primitives:DataGridColumnHeader">
                <Setter Property="Background" Value="#F9FAFB"/>
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="16,0"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                <Setter Property="Height" Value="48"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

            <Style x:Key="TextBlockButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
            </Style>

            <!-- Global Input Styles -->
            <Style TargetType="TextBox">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="RequestedTheme" Value="Light"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

            <Style TargetType="PasswordBox">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="PasswordRevealMode" Value="Hidden"/>
                <Setter Property="RequestedTheme" Value="Light"/>
            </Style>

            <Style TargetType="AutoSuggestBox">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="RequestedTheme" Value="Light"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
